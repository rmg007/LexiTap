# Copy this file to .env for local development.
# All EXPO_PUBLIC_* vars are inlined into the client bundle at build time.
# Server-side secrets (no EXPO_PUBLIC_ prefix) are for EAS Build workers only.

# --- RevenueCat ---
EXPO_PUBLIC_REVENUCAT_API_KEY=

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry (optional; dev/staging only — gated by NODE_ENV) ---
EXPO_PUBLIC_SENTRY_DSN=
