# LexiTap Environment Variables
#
# Copy this file to .env and fill in your values for local development.
# Never commit .env with actual secrets — .env.example is the template only.
#
# Note: EXPO_PUBLIC_* variables are inlined into the client bundle at build time
# by the Expo bundler. Server-side secrets (no EXPO_PUBLIC_ prefix) are for
# EAS Build workers only.

# ============================================================================
# SUPABASE (Required)
# ============================================================================
# Backend auth, database, and storage.
# Get these from your Supabase project dashboard: https://app.supabase.com
# Mobile app will fail to initialize if these are missing.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ============================================================================
# ANALYTICS (Optional — PostHog)
# ============================================================================
# App improvement analytics. Noop if unset.
# Get API key from PostHog dashboard: https://app.posthog.com
#
# Production allowed: YES (env-gated)
# Purpose: App retention, conversion, funnel health (anonymous only, no PII)
# Implementation: anon_id pseudonymity, autocapture off, EU host, no identity
# Default: Noop (analytics disabled if unset)

EXPO_PUBLIC_POSTHOG_API_KEY=

# ============================================================================
# CRASH REPORTING (Optional — Sentry)
# ============================================================================
# Production error tracking. Noop if unset.
# Get DSN from Sentry project settings: https://sentry.io
#
# Production allowed: YES (env-gated)
# Purpose: Crash telemetry and error diagnostics
# Implementation: PII-scrubbed (beforeSend/beforeBreadcrumb filter)
# Default: Noop (crash reporting disabled if unset)

EXPO_PUBLIC_SENTRY_DSN=

# ============================================================================
# PAYMENTS (Optional — RevenueCat)
# ============================================================================
# In-app purchase adapter. Noop if unset.
# Get API key from RevenueCat dashboard: https://dashboard.revenuecat.com
#
# Production allowed: NO (Phase 3 deferred; StubIapService in use)
# Purpose: IAP receipt validation and entitlement management
# Default: Noop (payments disabled if unset)

EXPO_PUBLIC_REVENUCAT_API_KEY=

# ============================================================================
# CONTENT ENRICHMENT (Optional — Anthropic)
# ============================================================================
# Claude API for C4 content enrichment (content-tool only, NOT mobile).
# Get API key from Anthropic console: https://console.anthropic.com
#
# Required for: npm run enrich (content-tool CSV enrichment mode)
# Purpose: Auto-generate context, etymology, usage examples for vocabulary
# Default: Content tool runs in stub mode (CSV passthrough, no API calls)
# Usage: cd content-tool && ANTHROPIC_API_KEY=sk-... npm run enrich

ANTHROPIC_API_KEY=

# ============================================================================
# IMAGE GENERATION (Optional — OpenAI gpt-image-1)
# ============================================================================
# AI raster image generation (scripts/generate-image.js, build-tooling only,
# NOT mobile). og-images, marketing art, content illustrations, icon explorations.
# Get API key from OpenAI dashboard: https://platform.openai.com/api-keys
#
# Required for: node scripts/generate-image.js "<prompt>"
# Purpose: Generate PNGs from text prompts (gpt-image-1)
# Default: script errors out if unset (no Noop — generation is explicit/on-demand)
# Never bundled into the mobile app; server/dev-tooling secret only.

OPENAI_API_KEY=

# ============================================================================
# SUPABASE MCP (Optional — agent tooling, NOT the app)
# ============================================================================
# Personal access token for the Supabase MCP server (.mcp.json). Lets agents
# inspect tables/RLS/buckets/edge-functions inline. Read-only by default.
# Create at: https://supabase.com/dashboard/account/tokens
# This is a DEV/agent secret — never bundled into mobile, never committed.
# Export in your shell or add here; .mcp.json reads ${SUPABASE_ACCESS_TOKEN}.

SUPABASE_ACCESS_TOKEN=

# ============================================================================
# NODE ENVIRONMENT (Optional)
# ============================================================================
# Affects build behavior and logger output.
# Valid values: development, test, production
# Default: development (Expo defaults to this for local dev)

NODE_ENV=development

# ============================================================================
# GOOGLE SIGN-IN (Optional — AUTH-1, iOS only)
# ============================================================================
# iOS OAuth client ID from Google Cloud Console (bundle ID com.lexitap.app).
# Hidden/Noop if unset: the in-app Google button doesn't render and the
# @react-native-google-signin config plugin is skipped (credential-less builds
# stay green). Set as an EAS secret for store builds. See mobile/AUTH_INTEGRATION.md.

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
