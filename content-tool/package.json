{
  "name": "lexitap-content-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Track A: builds the bundled read-only words.db for LexiTap",
  "type": "module",
  "bin": {
    "lexitap-tool": "./dist/cli.js"
  },
  "scripts": {
    "build:db": "tsx src/cli.ts export",
    "cli": "tsx src/cli.ts",
    "qa:sample": "tsx src/qa/cli.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
