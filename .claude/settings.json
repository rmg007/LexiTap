{
  "model": "sonnet",
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\"",
    "padding": 2,
    "refreshInterval": 5
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guardrails.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '\n📋 Session ending. Did you update CLAUDE.md or AGENTS.md? If architectural decisions were made this session, commit and push before /clear.'"
          },
          {
            "type": "command",
            "command": "bash -c 'git rev-parse --git-dir >/dev/null 2>&1 || exit 0; if git rev-parse --abbrev-ref \"@{u}\" >/dev/null 2>&1; then a=$(git rev-list --count \"@{u}..HEAD\" 2>/dev/null); if [ \"${a:-0}\" != \"0\" ]; then echo \"⚠️ ${a} unpushed commit(s) — push before /clear.\"; fi; else echo \"⚠️ branch has no upstream — git push -u origin HEAD before /clear.\"; fi; if [ -n \"$(git status --porcelain 2>/dev/null)\" ]; then echo \"⚠️ uncommitted changes in working tree — commit before /clear (repo is memory).\"; fi; exit 0'"
          },
          {
            "type": "command",
            "command": "command -v osascript >/dev/null && osascript -e 'display notification \"Response complete\" with title \"Claude Code — LexiTap\" sound name \"Glass\"' 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-context.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git merge-base:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(cd mobile && npm run check)",
      "Bash(cd mobile && npm run test:*)",
      "Bash(cd mobile && npm run lint:*)",
      "Bash(cd mobile && npm run typecheck:*)",
      "Bash(cd content-tool && npm run check)",
      "Bash(cd content-tool && npm run test:*)",
      "Bash(cd content-tool && npm run lint:*)",
      "Bash(cd content-tool && npm run typecheck:*)",
      "Bash(npm run check --workspace=:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(node scripts/generate-image.js:*)",
      "Bash(node scripts/generate-icon.js:*)",
      "Bash(node scripts/optimize-asset.js:*)",
      "Bash(npm run gen:image:*)",
      "Bash(npm run gen:icon:*)",
      "Bash(npm run optimize:*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Edit(mobile/src/infrastructure/db/**)",
      "Edit(mobile/src/domain/srs/**)",
      "Edit(mobile/src/infrastructure/iap/**)",
      "Edit(mobile/src/infrastructure/storage/**)",
      "Edit(mobile/src/infrastructure/crash/**)",
      "Edit(mobile/app.json)",
      "Edit(**/.env.development)",
      "Edit(**/.env.development.local)",
      "Edit(**/.env.production)",
      "Edit(**/.env.production.local)",
      "Edit(**/.env.staging)",
      "Edit(**/.env.test)"
    ]
  }
}
