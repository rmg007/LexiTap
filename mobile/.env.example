EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Product analytics (PostHog, `phc_...`). Runtime key — safe to ship; Noop if
# unset. Allowed in production: anon_id-only (no PII), autocapture-off, EU-hosted,
# in-app opt-out, app-improvement metrics only (src/infrastructure/analytics;
# privacy policy §5). NOT for ads/cross-app tracking/selling data.
EXPO_PUBLIC_POSTHOG_API_KEY=

# Crash reporting (Sentry). Runtime DSN — safe to ship; inert if unset. Allowed
# in production: events are PII-scrubbed on-device (src/infrastructure/crash).
EXPO_PUBLIC_SENTRY_DSN=
# Build-time only (set as EAS secrets) — source-map upload (RELEASE_PLAN B3).
# Leave unset until a Sentry project exists; the Expo plugin is skipped without
# org + project, so credential-less builds don't break.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Google Sign-In iOS OAuth client ID (AUTH-1). Hidden/Noop if unset — the
# Google button doesn't render and the config plugin is skipped.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
