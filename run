#!/usr/bin/env bash
# Run LexiTap on the iOS simulator.
#
# Usage:
#   ./run            — dev build (Metro + live reload)
#   ./run --release  — Release build (embedded bundle, no Metro; required for Maestro E2E)
#
# The Release build requires SENTRY_DISABLE_AUTO_UPLOAD=true to prevent
# sentry-cli from blocking the build on a failed source-map upload.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MOBILE="$SCRIPT_DIR/mobile"

RELEASE=false
for arg in "$@"; do
  case "$arg" in
    --release) RELEASE=true ;;
    *) echo "Unknown argument: $arg" >&2; exit 1 ;;
  esac
done

cd "$MOBILE"

if $RELEASE; then
  echo "Building Release (no Metro)…"
  SENTRY_DISABLE_AUTO_UPLOAD=true npx expo run:ios \
    --device "2FBE3837-C047-4E1D-9A3E-849EEBFA0478" \
    --configuration Release \
    --no-bundler
else
  echo "Building Debug (Metro + live reload)…"
  npx expo run:ios
fi
